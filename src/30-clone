#!/usr/bin/bash

clone_database () {
    # Copy the pacman database to the pacoff directory.
    #
    # The caller should have already chdir-ed into the pacoff
    # directory. This functon will not clobber any existing files, so
    # those must be removed beforehand.
    #
    # $1 -- Location of the pacman database (e.g., '/var/lib/pacman')
    # $2 -- (bool) Whether 'file' (-F) dbs should be copied
    [[ -e "$PACOFF_STATE_DB" ]] &&
        return $EX_EXISTS
    
    mkdir -- "$PACOFF_STATE_DB"
    
    cp -R -- "$1/local" "$PACOFF_STATE_DB/local"
    
    mkdir -- "$PACOFF_STATE_DB/sync"
    cp -- $(find "$1/sync" -maxdepth 1 -type f -name '*.db') "$PACOFF_STATE_DB/sync/"
    [[ "$2" = true ]] &&
        cp -- $(find "$1/sync" -maxdepth 1 -type f -name '*.files') "$PACOFF_STATE_DB/sync/"
    
    return 0
}


clone_keyring () {
    # Copy the pacman GPG keys to the pacoff directory.
    #
    # The caller should have already chdir-ed into the pacoff
    # directory. This functon will not clobber any existing files, so
    # those must be removed beforehand.
    #
    # $1 -- Location of the pacman keyring (e.g., '/etc/pacman.d/gnupg')
    [[ -e "$PACOFF_STATE_KEYRING" ]] &&
        return $EX_EXISTS
    
    mkdir -- "$PACOFF_STATE_KEYRING"
    cp -- $(find "$1" -maxdepth 1 -type f -perm -0444) "$PACOFF_STATE_KEYRING/"
    
    return 0
}


clone_operation () {
    # Create a new pacoff directory using pacman's data.
    #
    # $1 -- New directory in which to store pacoff's data
    # $2 -- Location of the pacman database (e.g., '/var/lib/pacman')
    # $3 -- Location of the pacman keyring (e.g., '/etc/pacman.d/gnupg')
    # $4 -- (bool) Whether 'file' (-F) dbs should be copied
    [[ -e "$1" ]] &&
        return $EX_EXISTS
    
    mkdir -- "$1"
    cd -- "$1"
    
    pacoff --version > "$PACOFF_STATE_ID"
    mkdir -- "$PACOFF_STATE_CACHE"
    touch -- "$PACOFF_STATE_PKGLIST"
    touch -- "$PACOFF_STATE_PACMANLOG"
    touch -- "$PACOFF_STATE_SELFLOG"
    cp -- "$PACOFF_PACMAN_PACMANCONF" "$PACOFF_STATE_PACMANCONF"
    
    [[ -f "$PACOFF_PACMAN_MIRRORLIST" ]] &&
        cp -- "$PACOFF_PACMAN_MIRRORLIST" "$PACOFF_STATE_MIRRORLIST"
    
    clone_database "$2" "$4"
    clone_keyring "$3"
    
    return 0
}
